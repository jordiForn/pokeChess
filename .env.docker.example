# =============================================================================
# PokeChess — variables Docker Compose (copiar a .env.docker en la raíz)
# =============================================================================
# cp .env.docker.example .env.docker
# =============================================================================

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=root_secret
MARIADB_DATABASE=pokechess
MARIADB_USER=pokechess
MARIADB_PASSWORD=pokechess_secret

# --- Build Angular: /api = mismo dominio (app.local o pokechess.local) ---
API_URL=/api

# --- Laravel (servicio php-fpm) ---
APP_NAME=PokeChess
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app.local
APP_TIMEZONE=UTC

FRONTEND_URL=http://app.local
CORS_ALLOWED_ORIGINS=http://app.local,http://pokechess.local,http://app.local:8080,http://pokechess.local:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=pokechess
DB_USERNAME=pokechess
DB_PASSWORD=pokechess_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=app.local,pokechess.local,api.app.local,api.pokechess.local,localhost,127.0.0.1

SEED_DB=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@pokechess.test"
MAIL_FROM_NAME="${APP_NAME}"
